# ─── Auth.js / NextAuth v5 ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth (console.cloud.google.com → APIs & Services → Credentials) ─
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev (SQLite — zero setup):
#   DATABASE_URL=file:./prisma/dev.db
#
# Production (PostgreSQL via Neon, Supabase, or DigitalOcean Managed DB):
#   DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require
#   DIRECT_URL=postgresql://user:pass@host:5432/db?sslmode=require  ← for migrations
#
DATABASE_URL=file:./prisma/dev.db
DIRECT_URL=

# ─── Database connection pool (optional — production tuning only) ─────────────
DB_CONNECTION_LIMIT=10
DB_CONNECTION_TIMEOUT=5
DB_POOL_TIMEOUT=10

# ─── App URL (used by Swagger UI, OAuth callbacks, email links) ───────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cloudflare R2 (file/attachment storage) ─────────────────────────────────
# Account ID: Cloudflare Dashboard → right sidebar
# Access keys: R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=                   # e.g. https://pub-xxx.r2.dev (if bucket is public)

# ─── Cloudflare R2 (optional — needed only for file attachments feature) ──────
# Leave blank if not using R2 in local dev

# ─── Sentry (error tracking + performance monitoring) ────────────────────────
# DSN: sentry.io → Project Settings → Client Keys
# Auth token: sentry.io → Settings → Auth Tokens (for source map uploads on CI)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Browserbase (cloud E2E testing) ─────────────────────────────────────────
# API key: app.browserbase.com → Settings → API Keys
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
BROWSERBASE_TEST_URL=http://localhost:3000
