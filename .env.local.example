# ─── Auth.js / NextAuth v5 ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth (console.cloud.google.com → APIs & Services → Credentials) ─
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev (SQLite — no extra setup needed):
#   DATABASE_URL=file:./prisma/dev.db
#
# Production (PostgreSQL via Neon, Supabase, or DigitalOcean Managed DB):
#   DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require
#   DIRECT_URL=postgresql://user:pass@host:5432/db?sslmode=require  (for migrations)
#
DATABASE_URL=file:./prisma/dev.db
DIRECT_URL=

# ─── Database connection pool tuning (optional — defaults shown) ──────────────
DB_CONNECTION_LIMIT=10
DB_CONNECTION_TIMEOUT=5
DB_POOL_TIMEOUT=10

# ─── Cloudflare R2 (file/attachment storage) ─────────────────────────────────
# Account ID: Cloudflare Dashboard → right sidebar
# Access keys: Cloudflare Dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=               # e.g. https://pub-xxx.r2.dev (if bucket is public)

# ─── Sentry (error tracking + performance monitoring) ────────────────────────
# DSN: sentry.io → Project Settings → Client Keys (DSN)
# Auth token: sentry.io → Settings → Auth Tokens (for source map uploads)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Browserbase (E2E testing — cloud browser sessions) ──────────────────────
# API key: browserbase.com → Dashboard → API Keys
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
BROWSERBASE_TEST_URL=http://localhost:3000
